{
  "extends": "@modern-js/tsconfig/base",
  "compilerOptions": {
    "target": "es2017",
    "module": "commonjs",
    "declaration": false,
    "jsx": "preserve",
    "baseUrl": "./",
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["./shared/*"],
      "@api/*": ["./src/api/lambda/*"]
    }
  },
  "include": ["src", "shared", "config", "modern.config.ts"],
  "exclude": ["**/node_modules"]
}
